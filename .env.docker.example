# ─── Dominio (sin https://) ────────────────────────────────────────────────
# Ejemplo: trazabilidad-interfruit.vzhjxa.easypanel.host
DOMAIN=

# ─── App ───────────────────────────────────────────────────────────────────
APP_SECRET=                    # php -r "echo bin2hex(random_bytes(32));"

# ─── Bases de datos ────────────────────────────────────────────────────────
DB_ROOT_PASSWORD=
DB_USER=trazabilidad
DB_PASSWORD=

# Se construyen automaticamente con los valores anteriores:
SECURITY_DATABASE_URL=mysql://${DB_USER}:${DB_PASSWORD}@db:3306/sistema_trazabilidad_security?serverVersion=8.0&charset=utf8mb4
CORE_DATABASE_URL=mysql://${DB_USER}:${DB_PASSWORD}@db:3306/sistema_trazabilidad_core?serverVersion=8.0&charset=utf8mb4

# ─── JWT ───────────────────────────────────────────────────────────────────
# Generar claves:
#   openssl genrsa -out private.pem -aes256 4096  (usa JWT_PASSPHRASE como passphrase)
#   openssl rsa -pubout -in private.pem -out public.pem
# Encodear a base64 (una sola linea):
#   base64 -w 0 private.pem
#   base64 -w 0 public.pem
JWT_PASSPHRASE=
JWT_PRIVATE_KEY_BASE64=
JWT_PUBLIC_KEY_BASE64=

# ─── CORS ──────────────────────────────────────────────────────────────────
# Debe incluir el dominio del frontend en produccion
CORS_ALLOW_ORIGIN=^https://TU_DOMINIO\.easypanel\.host$
